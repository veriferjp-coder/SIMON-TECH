# SIMON TECH - Environment Configuration
# Copy this file to .env and fill in your values

# Bot Configuration
BOT_NAME=SIMON TECH
PORT=3000
NODE_ENV=development

# WhatsApp Configuration
WHATSAPP_SESSION_NAME=SIMON_TECH_SESSION

# API Configuration (Optional)
API_KEY=your_api_key_here
API_BASE_URL=https://api.example.com

# Logging
LOG_LEVEL=info

# Database (Optional)
DB_URL=mongodb://localhost:27017/simon-tech
